# Kerfox auth + backend config template
# Copy this file to .env and fill in real values for local development.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OAuth provider toggles (true or false)
VITE_AUTH_GOOGLE_ENABLED=false
VITE_AUTH_GITHUB_ENABLED=false
VITE_AUTH_MICROSOFT_ENABLED=false

# Optional callback target for future auth flow wiring
VITE_AUTH_REDIRECT_URL=http://127.0.0.1:5173/auth/callback
